{
  "name": "flowkey",
  "displayName": "FlowKey",
  "description": "HUD, flow editor, and accessibility triggers for VS Code.",
  "version": "0.1.1",
  "publisher": "CarlosLeon",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/BarrileteChapin/FlowKey.git"
  },
  "bugs": {
    "url": "https://github.com/BarrileteChapin/FlowKey/issues"
  },
  "homepage": "https://github.com/BarrileteChapin/FlowKey#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "productivity",
    "workflow",
    "hud",
    "automation",
    "accessibility",
    "gestures",
    "voice",
    "commands"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "media/marketplace-icon.png",
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "media/**",
    "node_modules/@vscode/codicons/dist/**",
    "LICENSE",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flowkey",
          "title": "FlowKey",
          "icon": "media/flowkey-icon.svg"
        }
      ]
    },
    "views": {
      "flowkey": [
        {
          "id": "flowkey.quickActions",
          "name": "Quick Actions"
        },
        {
          "id": "flowkey.settings",
          "name": "Settings",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "flowkey.openHud",
        "title": "FlowKey: Open HUD"
      },
      {
        "command": "flowkey.closeHud",
        "title": "FlowKey: Close HUD"
      },
      {
        "command": "flowkey.toggleHud",
        "title": "FlowKey: Toggle HUD"
      },
      {
        "command": "flowkey.openWindowLauncher",
        "title": "FlowKey: Open Window Launcher"
      },
      {
        "command": "flowkey.handleLauncherTrigger",
        "title": "FlowKey: Handle Launcher Trigger"
      },
      {
        "command": "flowkey.openSettings",
        "title": "FlowKey: Open Settings"
      },
      {
        "command": "flowkey.openFlowEditor",
        "title": "FlowKey: Open Flow Editor"
      },
      {
        "command": "flowkey.closeFlowEditor",
        "title": "FlowKey: Close Flow Editor"
      },
      {
        "command": "flowkey.openAccessibility",
        "title": "FlowKey: Open Accessibility Panel"
      },
      {
        "command": "flowkey.closeAccessibility",
        "title": "FlowKey: Close Accessibility Panel"
      },
      {
        "command": "flowkey.exportPack",
        "title": "FlowKey: Export Workspace Pack"
      },
      {
        "command": "flowkey.importPack",
        "title": "FlowKey: Import Workspace Pack"
      },
      {
        "command": "flowkey.ai.explainSelection",
        "title": "FlowKey: AI Explain Selection"
      },
      {
        "command": "flowkey.ai.fixSelection",
        "title": "FlowKey: AI Fix Selection"
      },
      {
        "command": "flowkey.ai.generateFromPrompt",
        "title": "FlowKey: AI Generate From Prompt"
      }
    ],
    "keybindings": [
      {
        "command": "flowkey.handleLauncherTrigger",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k"
      },
      {
        "command": "flowkey.toggleHud",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      },
      {
        "command": "flowkey.openFlowEditor",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f"
      },
      {
        "command": "flowkey.openAccessibility",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:host && npm run build:webview",
    "build:host": "node esbuild.js",
    "build:webview": "node scripts/build-webviews.js",
    "watch:host": "node esbuild.js --watch",
    "watch:webview": "cd webview-ui && npx vite build --watch",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "npm run test:quick",
    "test:quick": "npm run test:unit",
    "test:full": "npm run test:unit && npm run test:webview",
    "test:unit": "vitest run --config vitest.config.ts test/unit",
    "test:webview": "vitest run --config vitest.config.ts test/webview",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "node ./dist/test/runIntegration.js",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.38"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.0",
    "eslint": "^8.56.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.3.0",
    "vite": "^8.0.3",
    "vitest": "^1.2.0"
  }
}
